+/*
+/* Forward declaration for utility functions
+*/
+static bool verify_token_signatures(cca_token_t *token);
+static bool verify_platform_components_if_enabled(cca_token_t *token, const char *ref_json_file);
+
+static int detect_cert_format(const unsigned char *cert_data, size_t cert_len)
+{
+    if (cert_len < 10) {
+        return -1; /* Too short to determine format */
+    }
+
+    /* Check for PEM header */
+    if (strstr((const char*)cert_data, "-----BEGIN CERTIFICATE-----") != NULL) {
+        return 1; /* PEM format */
+    }
+
+    /* Check for DER format (ASN.1 BER/DER starts with 0x30) */
+    if (cert_data[0] == 0x30) {
+        return 0; /* DER format */
+    }
+
+    return -1; /* Unknown format */
+}
+
+static int save_dev_cert(const char *prefix, const char * filename, const char *dev_cert, const size_t dev_cert_len)
+{
+    char fullpath[PATH_MAX] = {0};
+    FILE *fp = NULL;
+    const unsigned char *cert_data = (const unsigned char *)dev_cert;
+
+    snprintf(fullpath, sizeof(fullpath), "%s/%s", prefix, filename);
+    fp = fopen(fullpath, "wb");
+    if (!fp) {
+        RTLS_ERR("Cannot open dev cert file %s\n", fullpath);
+        return 1;
+    }
+
+    /* Detect certificate format and parse accordingly */
+    X509 *cert = NULL;
+    int cert_format = detect_cert_format(cert_data, dev_cert_len);
+    
+    RTLS_INFO("Detected certificate format: ");
+    
+    if (cert_format == 0) {
+        /* DER format */
+        RTLS_INFO("DER\n");
+        cert = d2i_X509(NULL, &cert_data, dev_cert_len);
+        if (!cert) {
+            RTLS_ERR("Failed to parse DER certificate\n");
+            fclose(fp);
+            return 1;
+        }
+    } else if (cert_format == 1) {
+        /* PEM format */
+        RTLS_INFO("PEM\n");
+        BIO *bio = BIO_new_mem_buf(cert_data, dev_cert_len);
+        if (bio) {
+            cert = PEM_read_bio_X509(bio, NULL, NULL, NULL);
+            BIO_free(bio);
+        }
+        if (!cert) {
+            RTLS_ERR("Failed to parse PEM certificate\n");
+            fclose(fp);
+            return 1;
+        }
+    } else {
+        /* Unknown format, try both formats as fallback */
+        RTLS_INFO("Unknown, trying DER first\n");
+        cert = d2i_X509(NULL, &cert_data, dev_cert_len);
+        if (!cert) {
+            RTLS_INFO("DER failed, trying PEM format\n");
+            cert_data = (const unsigned char *)dev_cert;
+            BIO *bio = BIO_new_mem_buf(cert_data, dev_cert_len);
+            if (bio) {
+                cert = PEM_read_bio_X509(bio, NULL, NULL, NULL);
+                BIO_free(bio);
+            }
+        }
+        
+        if (!cert) {
+            RTLS_ERR("Failed to parse certificate in any supported format\n");
+            fclose(fp);
+            return 1;
+        }
+    }
+
+    EVP_PKEY *pkey = X509_get_pubkey(cert);
+    if (pkey) {
+        int key_type = EVP_PKEY_base_id(pkey);
+        RTLS_INFO("Device certificate key type: %s\n",
+               key_type == EVP_PKEY_RSA ? "RSA" :
+               key_type == EVP_PKEY_EC ? "ECC" : "Unknown");
+        
+        if (key_type == EVP_PKEY_EC) {
+            EC_KEY *ec_key = EVP_PKEY_get1_EC_KEY(pkey);
+            if (ec_key) {
+                const EC_GROUP *group = EC_KEY_get0_group(ec_key);
+                if (group) {
+                    int curve_nid = EC_GROUP_get_curve_name(group);
+                    const char* curve_name = "Unknown";
+                    
+                    if (curve_nid == NID_secp521r1) {
+                        curve_name = "P-521";
+                    } else if (curve_nid == NID_secp384r1) {
+                        curve_name = "P-384";
+#ifdef NID_X9_62_prime256v1
+                    } else if (curve_nid == NID_X9_62_prime256v1) {
+                        curve_name = "P-256";
+#endif
+#ifdef NID_secp256r1
+                    } else if (curve_nid == NID_secp256r1) {
+                        curve_name = "P-256";
+#endif
+                    }
+                    
+                    RTLS_INFO("ECC curve: %s (NID: %d)\n", curve_name, curve_nid);
+                }
+                EC_KEY_free(ec_key);
+            }
+        }
+        EVP_PKEY_free(pkey);
+    }
+
+    /* Write certificate in PEM format */
+    if (PEM_write_X509(fp, cert) != 1) {
+        RTLS_ERR("Failed to write certificate to PEM file\n");
+        X509_free(cert);
+        fclose(fp);
+        return 1;
+    }
+
+    RTLS_INFO("Successfully saved device certificate to %s\n", fullpath);
+    X509_free(cert);
+    fclose(fp);
+    return 0;
+}
 
