+
+/*
+/* Verify CCA token signatures - supports both CVM-only and CVM+Platform tokens
+*/
+static bool verify_token_signatures(cca_token_t *token)
+{
+    cert_info_t cert_info;
+    
+    /* Detect AIK certificate type and configure certificate chain accordingly */
+    cert_type_t aik_cert_type = detect_aik_cert_type(DEFAULT_AIK_CERT_PEM_FILENAME);
+    configure_cert_info_by_type(&cert_info, aik_cert_type);
+
+    /*
+     * Support both legacy CVM-only tokens and complete attestation tokens (CVM and Platform)
+     * Check if platform token exists to determine verification mode
+     */
+    if (token->platform_cose.ptr != NULL && token->platform_cose.len > 0) {
+        /* Platform token exists - use new verification logic for CVM+Platform tokens */
+        RTLS_INFO("Verifying complete CCA token (CVM + Platform)\n");
+        return verify_cca_token_signatures(&cert_info,
+                                          token->platform_cose,
+                                          token->cvm_cose,
+                                          token->cvm_token.pub_key,
+                                          token->platform_token.challenge,
+                                          token->cvm_token.pub_key_hash_algo_id);
+    } else {
+        /*
+        /* No platform token - use legacy verification logic for CVM-only tokens
+        /* Create empty qbuf_t structures for compatibility
+        */
+        RTLS_INFO("Verifying legacy CVM-only token\n");
+        qbuf_t empty_buf = {.ptr = NULL, .len = 0};
+        return verify_cca_token_signatures(&cert_info,
+                                          empty_buf,  /* platform_cose */
+                                          token->cvm_cose,
+                                          token->cvm_token.pub_key,
+                                          empty_buf,  /* platform challenge */
+                                          token->cvm_token.pub_key_hash_algo_id);
+    }
+}
+
+/*
+/* Verify platform sw-components if enabled
+*/
+static bool verify_platform_components_if_enabled(cca_token_t *token, const char *ref_json_file)
+{
+    if (!ref_json_file || token->platform_cose.ptr == NULL || token->platform_cose.len == 0) {
+        /* No reference file or no platform token - skip verification */
+        return true;
+    }
+
+    platform_ref_values_t ref_values;
+    if (!load_platform_ref_values(ref_json_file, &ref_values)) {
+        RTLS_ERR("Failed to load platform reference values from: %s\n", ref_json_file);
+        return false;
+    }
+
+    bool result = verify_platform_sw_components(&token->platform_token, &ref_values);
+    
+    if (result) {
+        RTLS_INFO("Platform SW-Components verification PASSED\n");
+    } else {
+        RTLS_ERR("Platform SW-Components verification FAILED\n");
+    }
+    
+    free_platform_ref_values(&ref_values);
+    return result;
 }
