diff --git a/psi/kcal_adaptor/traffic_wrapper.cc b/psi/kcal_adaptor/traffic_wrapper.cc
new file mode 100644
index 0000000..4ea541f
--- /dev/null
+++ b/psi/kcal_adaptor/traffic_wrapper.cc
@@ -0,0 +1,26 @@
+#include "psi/kcal_adaptor/traffic_wrapper.h"
+
+#include "psi/kcal_adaptor/global_manager.h"
+
+namespace psi::kcal {
+
+int GlobalSendWrapper(struct TeeNodeInfo* nodeInfo, unsigned char* buf,
+                      unsigned long long len) {
+  yacl::Buffer msg(reinterpret_cast<void*>(buf), len);
+  std::string tag = "kcal_send";
+  auto lctx = GlobalManager::GetInstance().GetLink();
+  lctx->SendAsync(nodeInfo->nodeId, msg, tag);
+  return 0;
+}
+
+int GlobalRecvWrapper(struct TeeNodeInfo* nodeInfo, unsigned char* buf,
+                      unsigned long long* len) {
+  std::string tag = "kcal_recv";
+  auto lctx = GlobalManager::GetInstance().GetLink();
+  auto msg = lctx->Recv(nodeInfo->nodeId, tag);
+  memcpy(buf, msg.data(), msg.size());
+  *len = msg.size();
+  return 0;
+}
+
+}  // namespace psi::kcal
