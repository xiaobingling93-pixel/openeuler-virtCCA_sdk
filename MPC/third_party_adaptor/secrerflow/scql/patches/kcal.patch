+}
+
+void BinaryBase::ExecuteInKcal(ExecContext* ctx) {
+  const auto& left_pbs = ctx->GetInput(kInLeft);
+  const auto& right_pbs = ctx->GetInput(kInRight);
+  const auto& out_pbs = ctx->GetOutput(kOut);
+
+  auto kcal_ctx = ctx->GetSession()->GetKcalContext();
+  const auto& op_type = ctx->GetOpType();
+  SPDLOG_INFO("scql op type {}", op_type);
+  auto* share_store = ctx->GetSession()->GetKcalShareStore();
+
+  // TODO(shunde.csd): possible optimization
+  // maybe we should concatenate values together to reduce communication
+  // round-trip
+  for (int i = 0; i < left_pbs.size(); ++i) {
+    const auto& left_param = left_pbs[i];
+    const auto& right_param = right_pbs[i];
+    const auto& out_param = out_pbs[i];
+
+    kcal::io::KcalMpcShare* left_share = nullptr;
+    kcal::io::KcalMpcShare* right_share = nullptr;
+    int ret =
+        share_store->Get(kcal::GetKcalName(left_param.name()), left_share);
+    YACL_ENFORCE(ret, "Not find left share: {}",
+                 kcal::GetKcalName(left_param.name()));
+    ret = share_store->Get(kcal::GetKcalName(right_param.name()), right_share);
+    YACL_ENFORCE(ret, "Not find right share: {}",
+                 kcal::GetKcalName(right_param.name()));
+    auto shareSet =
