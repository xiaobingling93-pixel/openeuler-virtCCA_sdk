diff --git a/engine/kcal_adaptor/kcal_io_helper.cc b/engine/kcal_adaptor/kcal_io_helper.cc
new file mode 100644
index 0000000..aac665e
--- /dev/null
+++ b/engine/kcal_adaptor/kcal_io_helper.cc
@@ -0,0 +1,183 @@
+#include "engine/kcal_adaptor/kcal_io_helper.h"
+
+#include "engine/core/primitive_builder.h"
+#include "engine/util/ndarray_to_arrow.h"
+
+DECLARE_int64(provider_batch_size);
+
+namespace kcal {
+
+auto KcalInfeedHelper::TensorToArray(
+    std::shared_ptr<scql::engine::Tensor> tensor)
+    -> std::pair<spu::NdArrayRef, spu::PtType> {
+  auto array = scql::engine::util::ConcatenateChunkedArray(
+      tensor->ToArrowChunkedArray());
+  auto pt_view = spu_infeed_helper_->ConvertArrowArrayToPtView(array);
+  auto ptype = pt_view.value.pt_type;
+  SPDLOG_INFO("spu::PtType: {}", static_cast<int>(ptype));
+  return std::make_pair(ConvertToArray(pt_view.value), ptype);
+}
+
+int KcalInfeedHelper::TensorToTeeInput(
+    std::shared_ptr<scql::engine::Tensor> tensor,
+    kcal::io::KcalInput& tee_input) {
+  DG_TeeInput* kcal_input = tee_input.Get();
+  auto [array, ptype] = TensorToArray(tensor);
+  int64_t size = array.numel();
+  SPDLOG_INFO("tensor nums: {}", size);
+  std::unique_ptr<double[]> inData = std::make_unique<double[]>(size);
+  kcal_input->data.doubleNumbers = inData.release();
+  kcal_input->size = static_cast<int>(size);
+  kcal_input->dataType = DG_MpcDataType::MPC_DOUBLE;
+  SPDLOG_INFO("spu data to tee_input: spu type {}", static_cast<int>(ptype));
+
+  using namespace spu;
+  return DISPATCH_ALL_PT_TYPES(ptype, [&]() {
+    using T = ScalarT;
+    auto data = array.data<T>();
+    for (int64_t i = 0; i < size; i++) {
+      kcal_input->data.doubleNumbers[i] = double(data[i]);
+    }
+    return 0;
+  });
+}
+
+spu::NdArrayRef KcalInfeedHelper::ConvertToArray(spu::PtBufferView bv) {
+  using namespace spu;
+  const auto type = makePtType(bv.pt_type);
+  auto out = NdArrayRef(type, bv.shape);
+  SPDLOG_INFO("convertToArray spu::PtType: {}", static_cast<int>(bv.pt_type));
+  return DISPATCH_ALL_PT_TYPES(bv.pt_type, [&]() {
+    using T = ScalarT;
+    if (bv.shape.numel() > 0) {
+      auto* out_ptr = out.data<T>();
+
+      Index indices(bv.shape.size(), 0);
+      if (bv.isCompact()) {
+        std::memcpy(out_ptr, &bv.get<T>(indices), sizeof(T) * bv.shape.numel());
+      } else {
+        do {
+          *out_ptr = bv.get<T>(indices);
+          out_ptr += 1;
+        } while (bumpIndices(bv.shape, absl::MakeSpan(indices)));
+      }
+    }
+    return out;
+  });
+}
+
+std::string GetKcalName(const std::string& str) { return str + ".kcal"; }
+
+std::vector<std::string> BatchConvertToVecStr(
+    const std::vector<scql::engine::TensorPtr>& tensors) {
+  int64_t processed_item_cnt = tensors[0]->Length();
+
+  std::vector<std::string> res;
+  res.reserve(processed_item_cnt);
+
+  auto batch_provider = std::make_shared<scql::engine::util::BatchProvider>(
+      tensors, FLAGS_provider_batch_size);
+
+  std::vector<std::string> batch_items;
+  int64_t offset = 0;
+  while (processed_item_cnt > 0) {
+    std::vector<std::string> read_batch_items = batch_provider->ReadNextBatch();
+
+    if (read_batch_items.empty()) {
+      YACL_ENFORCE_EQ(processed_item_cnt, 0U);
+    }
+
+    res.insert(res.end(), read_batch_items.begin(), read_batch_items.end());
+    offset = offset + read_batch_items.size();
+
+    if (read_batch_items.size() <= processed_item_cnt) {
+      processed_item_cnt = processed_item_cnt - read_batch_items.size();
+    } else {
+      batch_items = std::vector<std::string>(
+          read_batch_items.begin() + processed_item_cnt,
+          read_batch_items.end());
+      processed_item_cnt = 0;
+    }
+  }
+
+  return res;
+}
+
+scql::engine::TensorPtr PsiResToTensorPtr(const DG_TeeOutput* output) {
+  scql::engine::TensorPtr array_ptr = nullptr;
+  scql::engine::Int64TensorBuilder int64_builder;
+  int64_builder.Reserve(output->size);
+
+  for (size_t idx = 0; idx < output->size; ++idx) {
+    if (output->data.u64Numbers[idx] == -1) {
+      int64_builder.AppendNull();
+    } else {
+      int64_builder.Append(static_cast<int64_t>(output->data.u64Numbers[idx]));
+    }
+  }
+
+  int64_builder.Finish(&array_ptr);
+
+  return array_ptr;
+}
+
+spu::PtType ToSpuPtType(DG_MpcDataType type) {
+  switch (type) {
+    case DG_MpcDataType::MPC_DOUBLE:
+      return spu::PtType::PT_F64;
+    case DG_MpcDataType::MPC_INT:
+      return spu::PtType::PT_I32;
+    default:
+      return spu::PtType::PT_INVALID;
+  }
+}
+
+spu::PtType ToSpuPtType(scql::pb::PrimitiveDataType pb_type) {
+  using namespace spu;
+  switch (pb_type) {
+    case scql::pb::PrimitiveDataType::BOOL:
+      return spu::PtType::PT_I1;
+    case scql::pb::PrimitiveDataType::INT32:
+      return spu::PtType::PT_I32;
+    case scql::pb::PrimitiveDataType::INT64:
+      return spu::PtType::PT_I64;
+    case scql::pb::PrimitiveDataType::FLOAT32:
+      return spu::PtType::PT_F32;
+    case scql::pb::PrimitiveDataType::FLOAT64:
+      return spu::PtType::PT_F64;
+    default:
+      return spu::PtType::PT_INVALID;
+  }
+}
+
+scql::engine::TensorPtr TeeOutputToScqlTensor(
+    DG_TeeOutput* tee_out, scql::pb::PrimitiveDataType out_type) {
+  auto size = tee_out->size;
+  SPDLOG_INFO("\033[31m tee output size: {} \033[0m", size);
+  spu::PtType spu_ptype = ToSpuPtType(out_type);
+  size_t elem_size = SizeOf(spu_ptype);
+  int64_t shape = tee_out->size;
+  SPDLOG_INFO("\033[31m spu::PtType: {} \033[0m", static_cast<int>(spu_ptype));
+  std::shared_ptr<yacl::Buffer> buf =
+      std::make_shared<yacl::Buffer>(size * sizeof(elem_size));
+  spu::NdArrayRef ret(spu::makePtType(spu_ptype), {shape});
+
+  using namespace spu;
+  return DISPATCH_ALL_PT_TYPES(spu_ptype, [&]() {
+    using T = ScalarT;
+    auto data_out = ret.data<T>();
+    if (tee_out->dataType == MPC_DOUBLE) {
+      for (int64_t i = 0; i < size; i++) {
+        data_out[i] = static_cast<T>(tee_out->data.doubleNumbers[i]);
+      }
+    } else if (tee_out->dataType == MPC_INT) {
+      for (int64_t i = 0; i < size; i++) {
+        data_out[i] = static_cast<T>(tee_out->data.u64Numbers[i]);
+      }
+    }
+    return scql::engine::TensorFrom(
+        scql::engine::util::NdArrayToArrow(ret, nullptr));
+  });
+}
+
+}  // namespace kcal
