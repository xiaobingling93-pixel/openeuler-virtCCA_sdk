+      auto op = kcal::OperatorManager::CreateOperator<kcal::Sub>(kcal_ctx);
+      YACL_ENFORCE(op != nullptr, "Create sub op failed.");
+      ret = op->Run(shareSet, out_share);
+    } else if (op_type == "Div") {
+      auto op = kcal::OperatorManager::CreateOperator<kcal::Div>(kcal_ctx);
+      YACL_ENFORCE(op != nullptr, "Create div op failed.");
+      ret = op->Run(shareSet, out_share);
+    } else if (op_type == "Less") {
+      auto op = kcal::OperatorManager::CreateOperator<kcal::Less>(kcal_ctx);
+      YACL_ENFORCE(op != nullptr, "Create less op failed.");
+      ret = op->Run(shareSet, out_share);
+    } else if (op_type == "Add") {
+      auto op = kcal::OperatorManager::CreateOperator<kcal::Add>(kcal_ctx);
+      YACL_ENFORCE(op != nullptr, "Create add op failed.");
+      ret = op->Run(shareSet, out_share);
+    } else if (op_type == "LessEqual") {
+      auto op =
+          kcal::OperatorManager::CreateOperator<kcal::LessEqual>(kcal_ctx);
+      YACL_ENFORCE(op != nullptr, "Create less equal op failed.");
+      ret = op->Run(shareSet, out_share);
+    } else if (op_type == "Greater") {
+      auto op = kcal::OperatorManager::CreateOperator<kcal::Greater>(kcal_ctx);
+      YACL_ENFORCE(op != nullptr, "Create greater op failed.");
+      ret = op->Run(shareSet, out_share);
+    } else if (op_type == "GreaterEqual") {
+      auto op =
+          kcal::OperatorManager::CreateOperator<kcal::GreaterEqual>(kcal_ctx);
+      YACL_ENFORCE(op != nullptr, "Create greater equal op failed.");
+      ret = op->Run(shareSet, out_share);
+    } else if (op_type == "Equal") {
+      auto op = kcal::OperatorManager::CreateOperator<kcal::Equal>(kcal_ctx);
+      YACL_ENFORCE(op != nullptr, "Create equal op failed.");
+      ret = op->Run(shareSet, out_share);
