+      SPDLOG_INFO("tensor {} to teeinput success", input_pb.name());
+    }
+    auto op = kcal::OperatorManager::CreateOperator<kcal::MakeShare>(kcal_ctx);
+    YACL_ENFORCE(op != nullptr, "Create make share op failed.");
+    auto* share = kcal::io::KcalMpcShare::Create();
