+  auto op = kcal::OperatorManager::CreateOperator<kcal::Psi>(kcal_ctx);
+  YACL_ENFORCE(op != nullptr, "Create psi op failed.");
+
+  kcal::io::KcalOutput output;
+  int ret =
+      op->Run(input.Get(), output.GetSecondaryPointer(), TEE_OUTPUT_INDEX);
+  YACL_ENFORCE(ret == DG_SUCCESS, "Psi op run failed. ret={}", ret);
+
+  auto join_indices = kcal::PsiResToTensorPtr(output.Get());
+  auto result_size = join_indices->Length();
