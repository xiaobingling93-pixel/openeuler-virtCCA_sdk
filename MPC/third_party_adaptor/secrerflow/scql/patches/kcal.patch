+void ReduceBase::KcalReduceImpl(ExecContext* ctx) {
+  const auto& input_pb = ctx->GetInput(kIn)[0];
+  const auto& output_pb = ctx->GetOutput(kOut)[0];
+
+  const auto& op_type = ctx->GetOpType();
+  SPDLOG_INFO("scql op type {}", op_type);
+
+  auto kcal_ctx = ctx->GetSession()->GetKcalContext();
+  auto* share_store = ctx->GetSession()->GetKcalShareStore();
+  auto kcal_in_name = kcal::GetKcalName(input_pb.name());
+  auto kcal_out_name = kcal::GetKcalName(output_pb.name());
+  kcal::io::KcalMpcShare* input_share = nullptr;
+  int ret = share_store->Get(kcal_in_name, input_share);
+  YACL_ENFORCE(ret, "Not find left share: {}", kcal_in_name);
+  auto shareSet = kcal::io::KcalMpcShareSet::Create({input_share});
+  auto* out_share = kcal::io::KcalMpcShare::Create();
+  if (op_type == "ReduceSum") {
+    auto op = kcal::OperatorManager::CreateOperator<kcal::Sum>(kcal_ctx);
+    YACL_ENFORCE(op != nullptr, "Create sum op failed.");
+    ret = op->Run(shareSet, out_share);
+  } else if (op_type == "ReduceAvg") {
+    auto op = kcal::OperatorManager::CreateOperator<kcal::Avg>(kcal_ctx);
+    YACL_ENFORCE(op != nullptr, "Create avg op failed.");
+    ret = op->Run(shareSet, out_share);
+  } else if (op_type == "ReduceMax") {
+    auto op = kcal::OperatorManager::CreateOperator<kcal::Max>(kcal_ctx);
+    YACL_ENFORCE(op != nullptr, "Create max op failed.");
+    ret = op->Run(shareSet, out_share);
+  } else if (op_type == "ReduceMin") {
+    auto op = kcal::OperatorManager::CreateOperator<kcal::Min>(kcal_ctx);
+    YACL_ENFORCE(op != nullptr, "Create min op failed.");
+    ret = op->Run(shareSet, out_share);
+  }
+  YACL_ENFORCE(ret == DG_SUCCESS, "KCAL operator run failed, ret: {}.", ret);
+  ctx->GetSession()->GetKcalShareStore()->Put(kcal_out_name, out_share);
+  SPDLOG_INFO("Put share: {}", kcal_out_name);
+}
