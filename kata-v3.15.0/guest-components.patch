diff --git a/attestation-agent/attester/src/virtcca/mod.rs b/attestation-agent/attester/src/virtcca/mod.rs
new file mode 100644
index 0000000..f9afd70
--- /dev/null
+++ b/attestation-agent/attester/src/virtcca/mod.rs
@@ -0,0 +1,91 @@
+// virtcca tee plugin
+//
+// Call the hardware sdk or driver to get the specific evidence
+
+use super::Attester;
+use anyhow::*;
+use iocuddle::{Group, Ioctl, WriteRead, Read};
+use serde::{Deserialize, Serialize};
+use std::path::Path;
+
+const VIRTCCA_GUEST_IOCTL: &str = "/dev/tsi";
+const VIRTCCA_REPORT_DATA_SIZE: usize = 64;
+const MAX_DEV_CERT_SIZE: usize = 4096;
+const GRANULE_SIZE: usize = 4096;
+const MAX_TOKEN_GRANULE_COUNT: usize = 2;
+
+pub fn detect_platform() -> bool {
+    Path::new(VIRTCCA_GUEST_IOCTL).exists()
+}
+
+#[derive(Debug, Default)]
+pub struct VirtccaAttester {}
+
+#[derive(Serialize, Deserialize)]
+pub struct VirtccaEvidence {
+    // virtcca token
+    pub evidence_virtcca: Vec<u8>,
+    // virtcca device certificate
+    pub dev_cert: Vec<u8>
+}
+
+#[repr(C)]
+pub struct CvmAttestationCmd {
+    challenge: [u8; VIRTCCA_REPORT_DATA_SIZE],
+    token: [u8; GRANULE_SIZE * MAX_TOKEN_GRANULE_COUNT],
+    token_size: u64,
+}
+
+#[repr(C)]
+pub struct VirtccaDevCert {
+    size: u64,
+    value: [u8; MAX_DEV_CERT_SIZE],
+}
+
+const TSI: Group = Group::new(b'T');
+const TSI_CMD_GET_TOKEN: Ioctl<WriteRead, &CvmAttestationCmd> = unsafe { TSI.write_read(0x1) };
+const TSI_CMD_GET_CERT: Ioctl<Read, &VirtccaDevCert> = unsafe { TSI.read(0x2) };
+
+#[async_trait::async_trait]
+impl Attester for VirtccaAttester {
+    async fn get_evidence(&self, mut report_data: Vec<u8>) -> Result<String> {
+        report_data.resize(VIRTCCA_REPORT_DATA_SIZE, 0);
+        let mut fd = std::fs::File::open(VIRTCCA_GUEST_IOCTL)
+        .context("Open virtCCA device failed")?;
+
+        let mut token_cmd = CvmAttestationCmd {
+            challenge: report_data.try_into().unwrap(),
+            token: [0u8; GRANULE_SIZE * MAX_TOKEN_GRANULE_COUNT],
+            token_size: 0,
+        };
+
+        TSI_CMD_GET_TOKEN
+            .ioctl(&mut fd, &mut token_cmd)
+            .context("Get virtcca attestation token failed")?;
+
+        let (_, cert_cmd) = TSI_CMD_GET_CERT
+                                .ioctl(&mut fd)
+                                .context("Get virtcca device cert failed")?;
+
+        let evidence = VirtccaEvidence {
+            evidence_virtcca: token_cmd.token[..token_cmd.token_size as usize].to_vec(),
+            dev_cert: cert_cmd.value[..cert_cmd.size as usize].to_vec(),
+        };
+
+        serde_json::to_string(&evidence).context("Serialize virtCCA evidence failed")
+    }
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[ignore]
+    #[tokio::test]
+    async fn test_virtcca_get_evidence() {
+        let attester = VirtccaAttester::default();
+        let report_data: Vec<u8> = vec![0; 48];
+        let evidence = attester.get_evidence(report_data).await;
+        assert!(evidence.is_ok());
+    }
+}
