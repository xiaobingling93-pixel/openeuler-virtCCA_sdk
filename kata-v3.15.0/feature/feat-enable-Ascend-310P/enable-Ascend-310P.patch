+base_os=$3
+APT_INSTALL="apt -o Dpkg::Options::='--force-confdef' -o Dpkg::Options::='--force-confold' -yqq --no-install-recommends install"
+
+export DEBIAN_FRONTEND=noninteractive
+
+setup_HwHiAiUser() {
+	groupadd HwHiAiUser
+	useradd -g HwHiAiUser -d /home/HwHiAiUser -m HwHiAiUser
+}
+
+setup_ascend_npu_driver() {
+	if [[ ! -f /"${run_file_name}" ]]; then
+		echo "chroot: Skipping Ascend driver installation"
+		return
+	fi
+
+	mv /"${run_file_name}" /root/
+
+	# pushd /root >> /dev/null
+	# # run_file_name="Ascend-hdk-310p-npu-driver_25.2.0_linux-aarch64.run"
+	# chmod +x ./"${run_file_name}"
+	# ./"${run_file_name}" --noexec --extract=./hdk_src
+	# ./"${run_file_name}" --repack-path=./hdk_src
+	# ./${run_file_name%.run}-custom.run --full
+	# popd >> /dev/null
+
+	pushd /root >> /dev/null
+	# 赋予执行权限
+	echo "为${run_file_name}添加执行权限"
+	chmod +x ./"${run_file_name}" || {
+		echo "Error: 无法为${run_file_name}添加执行权限"
+		popd >> /dev/null
+		return 1
+	}
+
+	# 解压步骤
+	echo "解压${run_file_name}"
+	./"${run_file_name}" --noexec --extract=./hdk_src || {
+		echo "Error: 解压${run_file_name}失败"
+		popd >> /dev/null
+		return 1
+	}
+
+	# sed -i '/modprobe_host_kos || return 1/s/^/#/' ./hdk_src/driver/script/run_driver_install.sh
+	# sed -i '/^modprobe_host_kos() {/a\    return 0' ./hdk_src/driver/script/run_driver_install.sh
+
+	# 处理repack步骤的交互式询问：自动输入n，并检查执行结果
+	echo "repack${run_file_name}"
+	# echo "n" | ./"${run_file_name}" --repack-path=./hdk_src
+	./"${run_file_name}" --repack-path=./hdk_src
+
+
+	# 执行custom安装（仅当repack成功时）
+	custom_run="${run_file_name%.run}-custom.run"
+	echo "install${custom_run}"
+	./"${custom_run}" --full || true
+
+	mv ./"${custom_run}" /"${custom_run}"
+	rm -rf ./*
+
+	popd >> /dev/null
+}
+
+install_libvirt_dependencies(){
+
+	# 定义要修改的shadow文件路径
+	SHADOW_FILE="/etc/shadow"
+
+	# 定义新的root密码哈希（使用单引号避免$被解析）
+	NEW_ROOT_HASH='$6$p0Mum0EdSA9A0gy.$07TkqgmbeZdb6VjDwmlqjP7lfiAEdIC858IZAB1SWp0SZKPlM3NfWSdlpEsdRhTmx.oXDmehmcFlB6JeFjSQu/'
+
+	# 使用#作为分隔符，避免与哈希中的/冲突
+	sed -i.bak "s#^root:.*#root:${NEW_ROOT_HASH}:20350:0:99999:7:::#" "$SHADOW_FILE"
+
+	# 进入 systemd 服务自启目录 
+	pushd /etc/systemd/system/getty.target.wants/  >> /dev/null
+	# 创建 ttyAMA0 的服务链接，复用 getty@.service 模板 
+	ln -s /lib/systemd/system/getty@.service getty@ttyAMA0.service 
+	popd >> /dev/null
+}
+
+install_build_dependencies() {
+	echo "chroot: Install Ascend drivers build dependencies"
+	eval "${APT_INSTALL}" make gcc pigz kmod pciutils udev net-tools vim isc-dhcp-client wget ncurses-term apt-utils
+}
+
+setup_apt_repositories() {
+	echo "chroot: Setup APT repositories for os version ${base_os}"
+	mkdir -p /var/cache/apt/archives/partial
+	mkdir -p /var/log/apt
+        mkdir -p /var/lib/dpkg/info
+        mkdir -p /var/lib/dpkg/updates
+        mkdir -p /var/lib/dpkg/alternatives
+        mkdir -p /var/lib/dpkg/triggers
+        mkdir -p /var/lib/dpkg/parts
+	touch /var/lib/dpkg/status
+	rm -f /etc/apt/sources.list.d/*
+
+	# Changing the reference here also means changes needed for cuda_keyring
+	# and cuda apt repository see install_dcgm for details
+
+	# 判断是否为oracular版本，设置对应的源地址
+	if [ "${base_os}" = "oracular" ]; then
+		repo_url="http://old-releases.ubuntu.com/ubuntu/"
+	else
+		repo_url="http://ports.ubuntu.com/ubuntu-ports/"
+	fi
+
+	cat <<-CHROOT_EOF > /etc/apt/sources.list.d/"${base_os}".list
+		deb [arch=arm64] ${repo_url} ${base_os} main universe restricted multiverse
+		deb [arch=arm64] ${repo_url} ${base_os}-updates main universe restricted multiverse
+		deb [arch=arm64] ${repo_url} ${base_os}-backports main universe restricted multiverse
+		deb [arch=arm64] ${repo_url} ${base_os}-security main universe restricted multiverse
+	CHROOT_EOF
+
+	apt update
+}
