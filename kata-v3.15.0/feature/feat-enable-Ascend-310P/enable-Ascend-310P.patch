@@ -0,0 +1,51 @@
+#!/usr/bin/env bash
+
+set -euo pipefail
+[[ -n "${DEBUG}" ]] && set -x
+
+readonly BUILD_DIR="/kata-containers/tools/packaging/kata-deploy/local-build/build/"
+# catch errors and then assign
+script_dir="$(dirname "$(readlink -f "$0")")"
+readonly SCRIPT_DIR="${script_dir}/ascend"
+DEBUG=""
+
+setup_ascend_npu_rootfs() {
+    pushd "${ROOTFS_DIR:?}" >> /dev/null
+
+    local rootfs_type=${1:-""}
+	local os_version=${2:-""}
+
+    cp "${SCRIPT_DIR}/ascend_chroot.sh" ./ascend_chroot.sh
+
+    chmod +x ./ascend_chroot.sh
+
+	local appendix=""
+	if [[ "${rootfs_type}" == "confidential" ]]; then
+		appendix="-${rootfs_type}"
+	fi
+
+	mkdir -p "./usr/share/oci/hooks/prestart/"
+	cp -L "${BUILD_DIR}/ascend_hook.sh" "./usr/share/oci/hooks/prestart/"
+	chmod +x ./usr/share/oci/hooks/prestart/ascend_hook.sh
+
+	tar -xvf "${BUILD_DIR}"/kata-static-kernel-virtcca"${appendix}"-headers.tar.xz -C .
+
+	local run_file_name="Ascend-hdk-310p-npu-driver_25.2.0_linux-aarch64.run"
+	if [[ -f ${BUILD_DIR}/${run_file_name} ]]; then
+		cp -L "${BUILD_DIR}"/"${run_file_name}" ./"${run_file_name}"
+	fi
+
+	mount --rbind /dev ./dev
+	mount --make-rslave ./dev
+	mount -t proc /proc ./proc
+
+	chroot . /bin/bash -c "/ascend_chroot.sh $(uname -r) ${run_file_name} ${os_version}"
+
+	umount -R ./dev
+	umount ./proc
+
+	rm ./ascend_chroot.sh
+	rm ./*.deb
+
+	popd  >> /dev/null
+}
\ No newline at end of file
