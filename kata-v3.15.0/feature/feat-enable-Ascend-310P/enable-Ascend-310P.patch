+install_kernel_dependencies() {
+    echo "===== 开始检查要安装的内核包 ====="
+    
+    # 启用扩展通配符，过滤dbg包
+    shopt -s extglob
+    echo "匹配到的非dbg包列表："
+    ls -l /linux-!(*dbg*).deb  # 显示过滤后的包
+    
+    # 安装包
+    echo -e "\n===== 开始安装内核包 ====="
+    dpkg -i /linux-!(*dbg*).deb || {
+        echo "ERROR: 包安装失败"
+        return 1
+    }
+    shopt -u extglob  # 关闭扩展通配符
+    
+    # 动态查找内核头文件目录（处理名称不固定的情况）
+    echo -e "\n===== 开始查找内核头文件目录 ====="
+    # 匹配 /usr/src/ 下的 linux-headers-* 目录（排除可能的链接）
+    headers_dirs=(/usr/src/linux-headers-*)
+    # 过滤掉非目录项（如果有）
+    headers_dirs=($(for dir in "${headers_dirs[@]}"; do
+        [ -d "$dir" ] && echo "$dir"
+    done))
+    
+    # 检查找到的目录数量
+    if [ ${#headers_dirs[@]} -eq 0 ]; then
+        echo "ERROR: 未找到内核头文件目录（/usr/src/linux-headers-*）"
+        return 1
+    elif [ ${#headers_dirs[@]} -gt 1 ]; then
+        echo "ERROR: 找到多个内核头文件目录，无法确定使用哪个："
+        printf "%s\n" "${headers_dirs[@]}"
+        return 1
+    fi
+    
+    # 确认找到唯一目录
+    headers_dir="${headers_dirs[0]}"
+    echo "找到内核头文件目录：$headers_dir"
+    
+    # 创建架构目录链接（动态使用找到的目录）
+    echo -e "\n===== 创建架构目录链接 ====="
+    arm64_dir="$headers_dir/arch/arm64"
+    aarch64_link="$headers_dir/arch/aarch64"
+    
+    if [ -d "$arm64_dir" ]; then
+        ln -sfn "$arm64_dir" "$aarch64_link"  # -f 强制覆盖已存在的链接
+        echo "成功创建链接：$aarch64_link -> $arm64_dir"
+    else
+        echo "ERROR: 未找到 $arm64_dir 目录，无法创建链接"
+        return 1
+    fi
+    
+    echo -e "\n===== 所有操作完成 ====="
+}
+
