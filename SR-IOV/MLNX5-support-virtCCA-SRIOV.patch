diff --git a/drivers/infiniband/hw/mlx5/cq.c b/drivers/infiniband/hw/mlx5/cq.c
index 9773d2a3d97f..3fa929059ab3 100644
--- a/drivers/infiniband/hw/mlx5/cq.c
+++ b/drivers/infiniband/hw/mlx5/cq.c
@@ -37,6 +37,9 @@
 #include "mlx5_ib.h"
 #include "srq.h"
 #include "qp.h"
+#ifdef CONFIG_HISI_VIRTCCA_CODA
+#include <linux/mlx5/coda_mlx5.h>
+#endif
 
 static void mlx5_ib_cq_comp(struct mlx5_core_cq *cq, struct mlx5_eqe *eqe)
 {
@@ -657,10 +660,10 @@ int mlx5_ib_arm_cq(struct ib_cq *ibcq, enum ib_cq_notify_flags flags)
 		ret = 1;
 	spin_unlock_irqrestore(&cq->lock, irq_flags);
 
-	mlx5_cq_arm(&cq->mcq,
+	mlx5_cq_arm_hook(&cq->mcq,
 		    (flags & IB_CQ_SOLICITED_MASK) == IB_CQ_SOLICITED ?
 		    MLX5_CQ_DB_REQ_NOT_SOL : MLX5_CQ_DB_REQ_NOT,
-		    uar_page, to_mcq(ibcq)->mcq.cons_index);
+		    uar_page, to_mcq(ibcq)->mcq.cons_index, mdev->pdev);
 
 	return ret;
 }
diff --git a/drivers/infiniband/hw/mlx5/mem.c b/drivers/infiniband/hw/mlx5/mem.c
index 5a22be14d958..13f9c40cfc37 100644
--- a/drivers/infiniband/hw/mlx5/mem.c
+++ b/drivers/infiniband/hw/mlx5/mem.c
@@ -34,6 +34,9 @@
 #include <rdma/ib_umem_odp.h>
 #include "mlx5_ib.h"
 #include <linux/jiffies.h>
+#ifdef CONFIG_HISI_VIRTCCA_CODA
+#include <asm/virtcca_coda.h>
+#endif
 
 /*
  * Fill in a physical address list. ib_umem_num_dma_blocks() entries will be
@@ -148,8 +151,8 @@ static int post_send_nop(struct mlx5_ib_dev *dev, struct ib_qp *ibqp, u64 wr_id,
 	 * we hit doorbell
 	 */
 	wmb();
-	__iowrite64_copy(bf->bfreg->map + bf->offset, mmio_wqe,
-			 sizeof(mmio_wqe) / 8);
+	__iowrite64_copy_hook(bf->bfreg->map + bf->offset, mmio_wqe,
+			 sizeof(mmio_wqe) / 8, dev->mdev->pdev);
 
 	bf->offset ^= bf->buf_size;
 
diff --git a/drivers/infiniband/hw/mlx5/wr.c b/drivers/infiniband/hw/mlx5/wr.c
index 9947feb7fb8a..3698807bb16c 100644
--- a/drivers/infiniband/hw/mlx5/wr.c
+++ b/drivers/infiniband/hw/mlx5/wr.c
@@ -8,6 +8,9 @@
 #include <linux/mlx5/driver.h>
 #include "wr.h"
 #include "umr.h"
+#ifdef CONFIG_HISI_VIRTCCA_CODA
+#include <linux/mlx5/coda_mlx5.h>
+#endif
 
 static const u32 mlx5_ib_opcode[] = {
 	[IB_WR_SEND]				= MLX5_OPCODE_SEND,
@@ -1041,7 +1044,7 @@ void mlx5r_ring_db(struct mlx5_ib_qp *qp, unsigned int nreq,
 	 */
 	wmb();
 
-	mlx5_write64((__be32 *)ctrl, bf->bfreg->map + bf->offset);
+	mlx5_write64_hook((__be32 *)ctrl, bf->bfreg->map + bf->offset, to_mdev(qp->ibqp.device)->mdev->pdev);
 	/* Make sure doorbells don't leak out of SQ spinlock
 	 * and reach the HCA out of order.
 	 */
diff --git a/drivers/net/ethernet/mellanox/mlx5/core/cmd.c b/drivers/net/ethernet/mellanox/mlx5/core/cmd.c
index 3e6bd27f6315..1d59189dea36 100644
