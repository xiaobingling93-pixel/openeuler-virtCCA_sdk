+#ifdef CONFIG_HISI_VIRTCCA_CODA
+#include <asm/virtcca_coda.h>
+#endif
 
 struct mlx5_ifc_mbox_out_bits {
 	u8         status[0x8];
@@ -1053,7 +1056,7 @@ static void cmd_work_handler(struct work_struct *work)
 	/* ring doorbell after the descriptor is valid */
 	mlx5_core_dbg(dev, "writing 0x%x to command doorbell\n", 1 << ent->idx);
 	wmb();
-	iowrite32be(1 << ent->idx, &dev->iseg->cmd_dbell);
+	iowrite32be_hook(1 << ent->idx, &dev->iseg->cmd_dbell, dev->pdev);
 	/* if not in polling don't use ent after this point */
 	if (cmd_mode == CMD_MODE_POLLING || poll_cmd) {
 		poll_timeout(ent);
@@ -2215,7 +2218,7 @@ static void free_cmd_page(struct mlx5_core_dev *dev, struct mlx5_cmd *cmd)
 
 static u16 cmdif_rev(struct mlx5_core_dev *dev)
 {
-	return ioread32be(&dev->iseg->cmdif_rev_fw_sub) >> 16;
+	return ioread32be_hook(&dev->iseg->cmdif_rev_fw_sub, dev->pdev) >> 16;
 }
 
 int mlx5_cmd_init(struct mlx5_core_dev *dev)
@@ -2264,7 +2267,7 @@ int mlx5_cmd_enable(struct mlx5_core_dev *dev)
 		return -EINVAL;
 	}
 
-	cmd_l = ioread32be(&dev->iseg->cmdq_addr_l_sz) & 0xff;
+	cmd_l = ioread32be_hook(&dev->iseg->cmdq_addr_l_sz, dev->pdev) & 0xff;
 	cmd->vars.log_sz = cmd_l >> 4 & 0xf;
 	cmd->vars.log_stride = cmd_l & 0xf;
 	if (1 << cmd->vars.log_sz > MLX5_MAX_COMMANDS) {
@@ -2302,8 +2305,8 @@ int mlx5_cmd_enable(struct mlx5_core_dev *dev)
 		goto err_cmd_page;
 	}
 
-	iowrite32be(cmd_h, &dev->iseg->cmdq_addr_h);
-	iowrite32be(cmd_l, &dev->iseg->cmdq_addr_l_sz);
+	iowrite32be_hook(cmd_h, &dev->iseg->cmdq_addr_h, dev->pdev);
+	iowrite32be_hook(cmd_l, &dev->iseg->cmdq_addr_l_sz, dev->pdev);
 
 	/* Make sure firmware sees the complete address before we proceed */
 	wmb();
