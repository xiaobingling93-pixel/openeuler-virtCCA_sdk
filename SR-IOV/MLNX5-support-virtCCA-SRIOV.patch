new file mode 100644
index 000000000000..2826d8a0d878
--- /dev/null
+++ b/include/linux/mlx5/coda_mlx5.h
@@ -0,0 +1,74 @@
+/* SPDX-License-Identifier: GPL-2.0-only */
+/*
+ * Copyright (C) 2024. Huawei Technologies Co., Ltd. All rights reserved.
+ */
+
+#ifndef MLX5_CODA_H
+#define MLX5_CODA_H
+
+#include <linux/mlx5/driver.h>
+#include <linux/refcount.h>
+#include <linux/mlx5/cq.h>
+#include <linux/mlx5/doorbell.h>
+#include "../../../drivers/net/ethernet/mellanox/mlx5/core/wq.h"
+
+static inline void virtcca_mlx5_cq_arm(struct mlx5_core_cq *cq, u32 cmd,
+			       void __iomem *uar_page, u32 cons_index, struct pci_dev *pdev)
+{
+	__be32 doorbell[2];
+	u32 sn;
+	u32 ci;
+
+	sn = cq->arm_sn & 3;
+	ci = cons_index & 0xffffff;
+
+	*cq->arm_db = cpu_to_be32(sn << 28 | cmd | ci);
+
+	/* Make sure that the doorbell record in host memory is
+	 * written before ringing the doorbell via PCI MMIO.
+	 */
+	wmb();
+
+	doorbell[0] = cpu_to_be32(sn << 28 | cmd | ci);
+	doorbell[1] = cpu_to_be32(cq->cqn);
+
+	virtcca_pci_mmio_write(pdev, *(u64 *)doorbell, CVM_RW_64_BIT, uar_page + MLX5_CQ_DOORBELL);
+}
+
+static inline void mlx5_cq_arm_hook(struct mlx5_core_cq *cq, u32 cmd,
+			       void __iomem *uar_page, u32 cons_index, struct pci_dev *pdev)
+{
+    if (is_virtcca_cvm_enable() && is_cc_dev(pci_dev_id(pdev))) {
+        return virtcca_mlx5_cq_arm(cq, cmd, uar_page, cons_index, pdev);
+    }
+    return mlx5_cq_arm(cq, cmd, uar_page, cons_index);
+}
+
+static inline void mlx5e_notify_hw_hook(struct mlx5_wq_cyc *wq, u16 pc, void __iomem *uar_map,
+		struct mlx5_wqe_ctrl_seg *ctrl, struct pci_dev *pdev)
+{
+    ctrl->fm_ce_se |= MLX5_WQE_CTRL_CQ_UPDATE;
+	/* ensure wqe is visible to device before updating doorbell record */
+	dma_wmb();
+
+	*wq->db = cpu_to_be32(pc);
+
+	/* ensure doorbell record is visible to device before ringing the
+	 * doorbell
+	 */
+	wmb();
+
+	if (is_virtcca_cvm_enable() && is_cc_dev(pci_dev_id(pdev))) {
+		return virtcca_pci_mmio_write(pdev, *(u64 *)ctrl, CVM_RW_64_BIT, uar_map);
+	}
+	mlx5_write64((__be32 *)ctrl, uar_map);
+}
+
+static inline void mlx5_write64_hook(__be32 val[2], void __iomem *dest, struct pci_dev *pdev)
+{
+    if (is_virtcca_cvm_enable() && is_cc_dev(pci_dev_id(pdev))) {
+        return virtcca_pci_mmio_write(pdev, *(u64 *)val, CVM_RW_64_BIT, dest);
+    }
+    return mlx5_write64(val, dest);
+}
+#endif /* MLX5_CODA_H */
